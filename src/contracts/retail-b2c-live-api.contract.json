{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crm.local/contracts/retail-b2c-live-api.contract.json",
  "schema": "retail.b2c.live_api.v1",
  "blockId": "retail-b2c",
  "build": "20260618-retail-live-api-routes-1",
  "contractVersion": "2026.06.18-retail-live-api-routes-1",
  "sourceOfTruth": {
    "core": "PostgreSQL crm_hub through Retail B2C backend proxy",
    "schema": "one_c_mirror",
    "browserRule": "Frontend stores only bounded visible pages and selected records."
  },
  "pagedEnvelope": {
    "canonicalCollectionField": "data",
    "compatibilityCollectionField": "items",
    "requiredFields": ["data", "limit", "offset", "hasMore"]
  },
  "liveReadEndpoints": [
    {
      "method": "GET",
      "path": "/api/live/products",
      "model": "Product",
      "defaultLimit": 20,
      "maxLimit": 100,
      "requiredFilters": [],
      "optionalFilters": ["search", "offset"],
      "sourceViews": ["one_c_mirror.crm_products_enriched"],
      "allowBrowserFullLoad": false
    },
    {
      "method": "GET",
      "path": "/api/live/counterparties",
      "model": "Counterparty",
      "defaultLimit": 20,
      "maxLimit": 100,
      "requiredFilters": [],
      "optionalFilters": ["search", "offset"],
      "sourceViews": ["one_c_mirror.crm_counterparties"],
      "allowBrowserFullLoad": false
    },
    {
      "method": "GET",
      "path": "/api/live/stock-balances",
      "model": "StockBalance",
      "defaultLimit": 20,
      "maxLimit": 5000,
      "requiredFilters": [],
      "optionalFilters": ["productCode", "warehouseCode", "search", "sort", "direction", "offset"],
      "sourceViews": ["one_c_mirror.crm_stock_balances", "one_c_mirror.crm_warehouses"],
      "allowBrowserFullLoad": false
    },
    {
      "method": "GET",
      "path": "/api/live/serial-stock",
      "model": "SerialStock",
      "defaultLimit": 20,
      "maxLimit": 100,
      "requiredFilters": ["productCode"],
      "optionalFilters": ["warehouseCode", "offset"],
      "sourceViews": ["one_c_mirror.crm_serial_stock_current", "one_c_mirror.crm_serial_stock_by_serial"],
      "allowBrowserFullLoad": false
    }
  ],
  "writePolicy": {
    "browserWritesToExternalSystems": false,
    "oneCWriteBack": "outbox-export-only",
    "requiresServerPermissionCheck": true
  },
  "domainRules": {
    "runtimeWired": false,
    "sales": "src/domain/sales-rules.mjs",
    "serials": "src/domain/serial-rules.mjs",
    "roles": "src/domain/role-rules.mjs",
    "liveQueries": "src/domain/live-query-rules.mjs"
  },
  "apiRoutes": {
    "runtimeWired": false,
    "liveReads": "src/api/live-read-routes.mjs"
  }
}
