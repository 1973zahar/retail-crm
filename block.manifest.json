  "hardRules": [
    "Do not touch marketplace-crm or B2B from this block.",
    "Do not expose import/export launch controls outside Data Exchange.",
    "Do not show import launch blocks inside directories.",
    "Do not switch workers through sidebar selectors; use login/logout sessions.",
    "Panel and Sale are one POS screen; do not add a separate dashboard sidebar item for Retail B2C.",
    "Only one computer/browser device may own an active session for one employee; a login from another computer replaces the previous employee session.",
    "Do not manually create products, prices, stock balances, serial numbers or receipts.",
    "Do not duplicate SQL core master data as the local source of truth.",
    "Do not load full product, stock, serial, customer, balance or order tables into browser state as production data; use bounded backend endpoints.",
    "Do not show or fetch serial numbers in the Stock reference screen until a selected product belongs to category/path Зброя.",
    "Do not paste passwords, secrets, raw .env, raw logs or credentials."
  ],
  "performanceGoals": {
    "firstScreenLoad": "fast bootstrap endpoint with minimal payload",
    "search": "server-side search/filter/page for large products, stock, serials and customers",
    "sync": "revision-based incremental state sync",
    "exchange": "background import/export jobs with visible progress",
    "ui": "all business info available in app screens without raw SQL/file inspection"
  },
